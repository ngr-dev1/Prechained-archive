    ],
    "default": [
      "std"
    ],
    "disable-timer": [
      "brotli-decompressor/disable-timer"
    ],
    "external-literal-probability": [],
    "pass-through-ffi-panics": [],
    "seccomp": [
      "brotli-decompressor/seccomp"
    ],
    "simd": [
      "packed_simd/into_bits"
    ],
    "std": [
      "alloc-stdlib",
      "brotli-decompressor/std"
    ],
    "validation": [
